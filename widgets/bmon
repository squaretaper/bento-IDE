#!/usr/bin/env python3
"""bmon — local system monitor for bento IDE.

Renders CPU, memory, disk I/O, temperatures, and network with
braille sparkline graphs.  Reads /proc and /sys on Linux.
"""

import time, os, sys
from collections import deque

INTERVAL = int(os.environ.get('BENTO_BMON_INTERVAL', '2'))

def read_file(path):
    try:
        with open(path) as f:
            return f.read().strip()
    except:
        return None

def get_cpu():
    with open('/proc/stat') as f:
        parts = f.readline().split()
    idle = int(parts[4]) + int(parts[5])
    total = sum(int(x) for x in parts[1:])
    return idle, total

# ── Braille rendering ─────────────────────────────────────────────

def spark(history, width, max_val=100):
    data = list(history)[-(width * 2):]
    while len(data) < width * 2:
        data.insert(0, 0)
    if len(data) % 2:
        data.insert(0, 0)

    left_dots  = [0x01, 0x02, 0x04, 0x40]
    right_dots = [0x08, 0x10, 0x20, 0x80]

    out = []
    for i in range(0, len(data), 2):
        l_val, r_val = data[i], data[i+1]
        l_level = 1 + int(l_val / max_val * 3) if max_val > 0 else 1
        r_level = 1 + int(r_val / max_val * 3) if max_val > 0 else 1
        l_level = max(1, min(l_level, 4))
        r_level = max(1, min(r_level, 4))
        code = 0x2800
        for d in range(l_level): code |= left_dots[d]
        for d in range(r_level): code |= right_dots[d]
        out.append(chr(code))

    if len(out) > width: out = out[-width:]
    while len(out) < width: out.insert(0, '\u2800')
    return ''.join(out)

FULL_BRAILLE = chr(0x2800 | 0x01 | 0x02 | 0x04 | 0x40 | 0x08 | 0x10 | 0x20 | 0x80)
HALF_L = chr(0x2800 | 0x01 | 0x02 | 0x04 | 0x40)

def braille_bar(pct, width):
    total_dots = width * 2
    filled = max(0, min(int(pct / 100 * total_dots), total_dots))
    filled_chars, empty_chars = [], []
    for i in range(width):
        left  = i * 2 < filled
        right = i * 2 + 1 < filled
        if left and right:   filled_chars.append(FULL_BRAILLE)
        elif left:           filled_chars.append(HALF_L)
        else:                empty_chars.append(FULL_BRAILLE)
    return ''.join(filled_chars), ''.join(empty_chars)

def fmt_rate(val, unit='B'):
    if val >= 1048576: return f'{val/1048576:.0f}G{unit}'
    if val >= 1024:    return f'{val/1024:.0f}M{unit}'
    return f'{val:.0f}K{unit}'

def color_val(val, low=60, high=85):
    GREEN  = '\033[32m'
    YELLOW = '\033[33m'
    RED    = '\033[31m'
    if val < low:  return GREEN
    if val < high: return YELLOW
    return RED

# ── Data sources ──────────────────────────────────────────────────

def get_net_interfaces():
    ifaces = []
    try:
        for name in os.listdir('/sys/class/net'):
            if name == 'lo': continue
            operstate = read_file(f'/sys/class/net/{name}/operstate')
            if operstate in ('up', 'unknown'):
                ifaces.append(name)
    except: pass
    return sorted(ifaces)

def get_disk_devices():
    devs = []
    try:
        with open('/proc/diskstats') as f:
            for line in f:
                p = line.split()
                name = p[2]
                if name in ('nvme0n1', 'sda', 'sdb', 'vda'):
                    devs.append((name, int(p[5]), int(p[9])))
    except: pass
    return devs

# ── Main loop ─────────────────────────────────────────────────────

def main():
    sys.stdout.write('\033[?1049h')
    sys.stdout.flush()

    # Standard ANSI colors — adapts to the user's terminal palette.
    BLUE  = '\033[34m'
    DIM   = '\033[2m'
    WHITE = '\033[37m'
    R     = '\033[0m'

    cpu_hist  = deque(maxlen=60)
    mem_hist  = deque(maxlen=60)
    disk_hist = deque(maxlen=60)

    prev_cpu = get_cpu()
    prev_net = {}
    for iface in get_net_interfaces():
        prev_net[iface] = (
            int(read_file(f'/sys/class/net/{iface}/statistics/rx_bytes') or 0),
            int(read_file(f'/sys/class/net/{iface}/statistics/tx_bytes') or 0),
        )

    prev_disk = {}
    for name, rd, wr in get_disk_devices():
        prev_disk[name] = (rd, wr)

    time.sleep(1)

    while True:
        try:    cols = os.get_terminal_size().columns
        except: cols = 30
        gw = max(cols - 2, 8)

        lines = ['\033[H\033[J']

        # ── CPU ──
        idle, total = get_cpu()
        di = idle - prev_cpu[0]
        dt = total - prev_cpu[1]
        cpu_pct = 100 * (1 - di / dt) if dt > 0 else 0
        prev_cpu = (idle, total)
        cpu_hist.append(cpu_pct)

        c = color_val(cpu_pct)
        lines.append(f' {BLUE}cpu{R} {c}{cpu_pct:.1f}%{R}')
        lines.append(f' {c}{spark(cpu_hist, gw)}{R}')
        lines.append('')

        # ── Memory ──
        with open('/proc/meminfo') as f:
            mi = {}
            for line in f:
                k, v = line.split(':')
                mi[k.strip()] = int(v.split()[0])
        mem_total = mi['MemTotal'] / 1048576
        mem_used = (mi['MemTotal'] - mi['MemAvailable']) / 1048576
        mem_pct = mem_used / mem_total * 100
        mem_hist.append(mem_pct)

        c = color_val(mem_pct)
        lines.append(f' {BLUE}mem{R} {c}{mem_used:.1f}{DIM}/{mem_total:.1f}GB{R}')
        lines.append(f' {c}{spark(mem_hist, gw)}{R}')
        lines.append('')

        # ── Disk I/O ──
        rd_total = wr_total = 0
        for name, rd, wr in get_disk_devices():
            prd, pwr = prev_disk.get(name, (rd, wr))
            rd_total += (rd - prd) * 512 // 1024
            wr_total += (wr - pwr) * 512 // 1024
            prev_disk[name] = (rd, wr)
        disk_hist.append(rd_total + wr_total)
        lines.append(f' {BLUE}i/o{R} {DIM}\u2193{R}{WHITE}{fmt_rate(rd_total)}{R} {DIM}\u2191{R}{WHITE}{fmt_rate(wr_total)}/s{R}')
        lines.append(f' {DIM}{spark(disk_hist, gw, 2200000)}{R}')
        lines.append('')

        # ── Temps ──
        temps = []
        i = 0
        while True:
            t = read_file(f'/sys/class/thermal/thermal_zone{i}/temp')
            n = read_file(f'/sys/class/thermal/thermal_zone{i}/type')
            if t is None: break
            t = int(t)
            if t > 1000: temps.append((n or f'zone{i}', t // 1000))
            i += 1
        temps.sort(key=lambda x: -x[1])

        GRAY   = '\033[37m'
        DKGRAY = '\033[2;37m'
        lines.append(f' {BLUE}temp{R}')
        for name, t in temps[:4]:
            c = color_val(t, 55, 75)
            prefix = f' {name[:6]:<6} {t:2d}\u00b0 '
            tw = max(cols - len(prefix) - 1, 4)
            filled, empty = braille_bar(min(t, 100), tw)
            lines.append(f' {WHITE}{name[:6]:<6}{R} {c}{t:2d}\u00b0{R} {GRAY}{filled}{DKGRAY}{empty}{R}')

        # ── Network ──
        lines.append('')
        lines.append(f' {BLUE}net{R}')
        for iface in get_net_interfaces():
            rx = int(read_file(f'/sys/class/net/{iface}/statistics/rx_bytes') or 0)
            tx = int(read_file(f'/sys/class/net/{iface}/statistics/tx_bytes') or 0)
            prx, ptx = prev_net.get(iface, (rx, tx))
            rx_s = (rx - prx) / 2048
            tx_s = (tx - ptx) / 2048
            prev_net[iface] = (rx, tx)
            lines.append(f' {WHITE}{iface[:8]}{R} {DIM}\u2193{R}{WHITE}{fmt_rate(rx_s)}{R} {DIM}\u2191{R}{WHITE}{fmt_rate(tx_s)}/s{R}')

        sys.stdout.write(''.join(l + '\n' for l in lines))
        sys.stdout.flush()
        time.sleep(INTERVAL)

if __name__ == '__main__':
    try:
        main()
    except KeyboardInterrupt:
        sys.stdout.write('\033[?1049l')
        sys.stdout.flush()
        sys.exit(0)
